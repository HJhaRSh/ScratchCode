datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LessonType {
  CONCEPT
  EXERCISE
  PROJECT
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum QuestDifficulty {
  MEDIUM
  HARD
  EXPERT
}

enum QuestAttemptStatus {
  ATTEMPTED
  SOLVED
  FAILED
}

model User {
  id                  String               @id @default(cuid())
  supabase_id         String               @unique
  username            String               @unique
  email               String               @unique
  avatar_url          String?
  xp                  Int                  @default(0)
  level               Int                  @default(1)
  streak_count        Int                  @default(0)
  streak_last_date    DateTime?
  streak_freeze_count Int                  @default(1)
  created_at          DateTime             @default(now())
  
  progress              UserLessonProgress[]
  badges                UserBadge[]
  hints                 HintUsage[]
  daily_quest_attempts  UserDailyQuestAttempt[]
  daily_quest_streak    DailyQuestStreak?
}

model Track {
  id           String   @id @default(cuid())
  slug         String   @unique // python | javascript | html-css | c-cpp | java
  title        String
  description  String
  icon         String
  color_hex    String?
  total_units  Int
  total_lessons Int
  is_published Boolean  @default(false)
  
  units        Unit[]
}

model Unit {
  id           String   @id @default(cuid())
  track_id     String
  track        Track    @relation(fields: [track_id], references: [id], onDelete: Cascade)
  unit_number  Int
  title        String
  description  String
  xp_reward    Int
  is_published Boolean  @default(false)
  
  lessons      Lesson[]
}

model Lesson {
  id               String               @id @default(cuid())
  unit_id          String
  unit             Unit                 @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  lesson_number    Int
  title            String
  type             LessonType
  duration_minutes Int
  content_json     Json
  starter_code     String?
  solution_code    String?
  test_cases_json  Json?
  xp_reward        Int
  language         String
  is_published     Boolean              @default(false)
  
  progress         UserLessonProgress[]
  hints            HintUsage[]
}

model UserLessonProgress {
  id            String         @id @default(cuid())
  user_id       String
  user          User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson_id     String
  lesson        Lesson         @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  status        ProgressStatus @default(NOT_STARTED)
  attempts      Int            @default(0)
  code_snapshot String?
  completed_at  DateTime?
  xp_earned     Int            @default(0)

  @@unique([user_id, lesson_id])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String
  icon_emoji  String
  
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  badge_id  String
  badge     Badge    @relation(fields: [badge_id], references: [id], onDelete: Cascade)
  earned_at DateTime @default(now())

  @@unique([user_id, badge_id])
}

model HintUsage {
  id            String   @id @default(cuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson_id     String
  lesson        Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  hint_number   Int
  requested_at  DateTime @default(now())
  response_text String
}

model DailyQuest {
  id                       String                  @id @default(cuid())
  dayNumber                Int                     @unique
  title                    String
  difficulty               QuestDifficulty
  description              String
  examples_json            Json
  constraints_json         Json
  hints_json               Json
  test_cases_json          Json
  solution_approaches_json Json
  optimal_approach         String
  tags                     String[]
  xp_reward                Int
  bonus_reward_json        Json
  created_at               DateTime                @default(now())

  attempts                 UserDailyQuestAttempt[]
}

model UserDailyQuestAttempt {
  id                String             @id @default(cuid())
  user_id           String
  user              User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  quest_id          String
  quest             DailyQuest         @relation(fields: [quest_id], references: [id], onDelete: Cascade)
  day_number        Int
  status            QuestAttemptStatus @default(ATTEMPTED)
  language          String
  submitted_code    String
  passed_tests      Int                @default(0)
  total_tests       Int                @default(10)
  xp_earned         Int                @default(0)
  bonus_earned_json Json?
  ai_feedback_json  Json?
  attempts_count    Int                @default(0)
  first_solved_at   DateTime?
  created_at        DateTime           @default(now())

  @@unique([user_id, day_number])
}

model DailyQuestStreak {
  id               String    @id @default(cuid())
  user_id          String    @unique
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  current_streak   Int       @default(0)
  longest_streak   Int       @default(0)
  last_solved_date DateTime?
  total_solved     Int       @default(0)
  created_at       DateTime  @default(now())
}
